VITE_CLI_PORT=8080
VITE_SERVER_PORT=8888
VITE_BASE_API=/api
VITE_BASE_PATH=http://127.0.0.1
# Optional combined-launcher override; defaults to server/index.js when omitted.
SERVE_SERVER_ENTRYPOINT=server/index.js
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seedance-2-0-260128
# Copy this file to the ignored .env.local for local secrets. The future Node
# adapter must load .env.development defaults first, then .env.local overrides.
ARK_API_KEY=
PUBLIC_MEDIA_BASE_URL=
APP_REAL_GENERATION_ENABLED=false
