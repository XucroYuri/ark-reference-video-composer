VITE_CLI_PORT=8080
VITE_SERVER_PORT=8888
VITE_BASE_API=/api
VITE_BASE_PATH=http://127.0.0.1
# Optional combined-launcher override; defaults to server/index.js when omitted.
SERVE_SERVER_ENTRYPOINT=server/index.js
# Optional Express bind host; defaults to 127.0.0.1.
SERVER_HOST=127.0.0.1

# Ark OpenAPI server-side settings. Keep ARK_API_KEY out of VITE_* variables.
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL=doubao-seedance-2-0-260128
# Copy this file to the ignored .env.local for local secrets. The future Node
# adapter must load .env.development defaults first, then .env.local overrides.
ARK_API_KEY=

# Public HTTPS base for uploaded files when real generation is enabled.
# Local /uploads URLs are valid for preview and Dry-run but Ark cannot fetch localhost.
PUBLIC_MEDIA_BASE_URL=

# Default false keeps the prototype in no-cost Dry-run mode.
APP_REAL_GENERATION_ENABLED=false
